        "    'BloodPressure': np.random.randint(60, 110, size=num_people),\n",
        "    'SkinThickness': np.random.randint(10, 50, size=num_people),\n",
        "    'Insulin': np.random.randint(15, 300, size=num_people),\n",
        "    'BMI': np.random.uniform(18.5, 40.0, size=num_people).round(1),\n",
        "    'DiabetesPedigree': np.random.uniform(0.1, 2.0, size=num_people).round(3),\n",
        "    'Age': np.random.randint(21, 70, size=num_people),\n",
        "    'Outcome': np.random.choice([0, 1], size=num_people, p=[0.65, 0.35])\n",
        "}\n",
        "\n",
        "data = pd.DataFrame(mock_data)\n",
        "\n",
        "print(\"--- YOUR DATASET GENERATED SUCCESSFULLY ---\")\n",
